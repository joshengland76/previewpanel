# ── PreviewPanel Environment Variables ──────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# TwelveLabs API key
# Get yours at: https://playground.twelvelabs.io/dashboard/api-keys
TWELVELABS_API_KEY=your_twelvelabs_api_key_here

# Anthropic API key (used as fallback to structure raw TwelveLabs output)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port (optional, defaults to 3001)
PORT=3001

# Instance id for analyze_tasks poller scoping (Phase B3, Task 1). Prevents two
# server processes sharing one Neon DB (e.g. a local dev server and the live
# Render deployment) from racing to claim each other's TwelveLabs polling
# tasks. Render's dashboard env config MUST set this to exactly "production" —
# it is not auto-detected. Leave unset locally; each dev machine defaults to
# "dev-<hostname>", which is enough to avoid collisions between developers too.
INSTANCE_ID=production

# Bearer token for POST /api/research/submit (correlation research project).
# Generate with: openssl rand -hex 32
# If unset, the endpoint rejects all requests with 401.
RESEARCH_API_KEY=your_long_random_string_here

# ── Capstone v2 shadow scoring (Phase B2) — all default OFF, invisible to users ──
# Master flag: write an invisible shadow_scores row per completed submission.
SHADOW_SCORING=false
# Sub-flag: run the C_dims v1 Claude extractor (adds ~$0.03/video, own key below).
# Excluded automatically for research_api-sourced submissions either way.
EXTRACT_CDIMS=false
# Dedicated key for C_dims extraction — separate from ANTHROPIC_API_KEY (same
# key-separation pattern as SYNTHESIS_ANTHROPIC_API_KEY) so a C_dims outage or
# quota issue can never affect judging or the synthesis feature.
CDIMS_ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Clamp duration_secs to scoring_spec_v2's duration_clamp_bounds [p1,p99] before
# shadow-scoring (default true). Only affects the shadow-scoring input; the
# scorer formula itself never clamps (see buildFeatures.js).
CLAMP_DURATION=true
# Dark-launched score-display feature (Phase B3, Task 5). Default OFF -- do
# NOT enable in production until B3's user-facing review is complete.
DISPLAY_SCORE=false

# Synthesis v2.5 -- score-aware hero line (gist leads with the dominant
# detected negative signal when one is high-impact). Default OFF; requires
# EXTRACT_CDIMS=true to have any effect (reads job.signalFields). Rollback =
# unset this flag, which reverts every job to the byte-identical v2.4 prompt.
SYNTHESIS_V25=false
